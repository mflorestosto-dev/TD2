ARM GAS  src/kernel/startup.s 			page 1


   1              	/*
   2              	_table_isr:
   3              	Contiene los punteros a los handlers. Cada vector de excepción carga la dirección de su handler c
   4              	
   5              	copy_loop:
   6              	Copia la tabla de vectores a la posición 0 (donde el procesador espera que estén los vectores). 
   7              	
   8              	idle:
   9              	Un bucle infinito para “esperar” o “dormir”.
  10              	 */
  11              	
  12              	.global _start
  13              	
  14              	//Handlers
  15              	.extern	_reset_vector
  16              	.extern handler_UND
  17              	.extern handler_SWI
  18              	.extern handler_prefetch_abort
  19              	.extern handler_data_abort
  20              	.extern handler_reserved
  21              	.extern handler_IRQ
  22              	.extern handler_FIQ
  23              	
  24              	//Stack pointers de los modos
  25              	.extern __stack_top_sys__ 
  26              	.extern __stack_top_svc__ 
  27              	.extern __stack_top_irq__
  28              	.extern __stack_top_fiq__
  29              	.extern __stack_top_abt__
  30              	.extern __stack_top_und__
  31              	
  32              	.extern board_init
  33              	
  34              	.code 32
  35              	
  36              	.section .start:
  37              	
  38              	_table_isr:
  39 0000 18F09FE5 		LDR PC, literal_reset_vector
  40 0004 18F09FE5 	    LDR PC, literal_undef_handler      // Undefined instruction
  41 0008 18F09FE5 	    LDR PC, literal_swi_handler        // Software interrupt
  42 000c 18F09FE5 	    LDR PC, literal_prefetch_abort     // Prefetch abort
  43 0010 18F09FE5 	    LDR PC, literal_data_abort         // Data abort
  44 0014 18F09FE5 	    LDR PC, literal_reserved_handler   // Reserved
  45 0018 18F09FE5 	    LDR PC, literal_irq_handler        // IRQ
  46 001c 18F09FE5 	    LDR PC, literal_fiq_handler        // FIQ
  47              	
  48              	
  49 0020 00000000 	    literal_reset_vector 		: .word _reset_vector
  50 0024 00000000 	    literal_undef_handler 		: .word handler_UND
  51 0028 00000000 	    literal_swi_handler 		: .word handler_SWI
  52 002c 00000000 	    literal_prefetch_abort 		: .word handler_prefetch_abort
  53 0030 00000000 	    literal_data_abort 			: .word handler_data_abort
  54 0034 00000000 	    literal_reserved_handler 	: .word handler_reserved
  55 0038 00000000 	    literal_irq_handler 		: .word handler_IRQ
  56 003c 00000000 	    literal_fiq_handler 		: .word handler_FIQ
  57              	
ARM GAS  src/kernel/startup.s 			page 2


  58              	
  59              	_start:
  60 0040 0000A0E3 	    LDR r0, = #0                    // Dirección destino (inicio de vectores)
  61 0044 48109FE5 	    LDR r1, = _table_isr            // Origen
  62 0048 48209FE5 	    LDR r2, = _start   
  63              	
  64              	_copy_loop:
  65 004c 043091E4 	    LDR r3, [r1], #4
  66 0050 043080E4 	    STR r3, [r0], #4
  67 0054 020051E1 		CMP r1, r2
  68 0058 FBFFFF1A 	    BNE _copy_loop            // Fin de la tabla
  69              	
  70              	    //Constantes para los modos de operacion
  71              	    .equ USR_MODE,  0x10 /*User         - CPSR[4:0] = 10000*/
  72              	    .equ FIQ_MODE,  0x11 /*FIQ          - CPSR[4:0] = 10001*/
  73              	    .equ IRQ_MODE,  0x12 /*IRQ          - CPSR[4:0] = 10010*/
  74              	    .equ SVC_MODE,  0x13 /*Supervisor   - CPSR[4:0] = 10011*/
  75              	    .equ ABT_MODE,  0x17 /*Abort        - CPSR[4:0] = 10111*/
  76              	    .equ UND_MODE,  0x1B /*Undefined    - CPSR[4:0] = 11011*/
  77              	    .equ SYS_MODE,  0x1F /*System       - CPSR[4:0] = 11111*/
  78              	
  79              	    .equ MASK,      0xC0 /*Mascara para poner en 1 el bit de la interrupcion a deshabilitar */
  80              	
  81              	_stack_init:
  82              	    // Modo FIQ
  83              	    //MSR cpsr_c, #(0x11 | 0xC0)  // Modo FIQ, deshabilitar IRQ/FIQ
  84              	    //LDR SP, = __stack_top_fiq__
  85              	
  86              	    // Modo IRQ
  87 005c D2F021E3 	    MSR cpsr_c, #(0x12 | 0xC0)  // Modo IRQ, deshabilitar IRQ/FIQ
  88 0060 34D09FE5 	    LDR SP, = __stack_top_irq__
  89              	
  90              	    // Modo Supervisor
  91 0064 D3F021E3 	    MSR cpsr_c, #(0x13 | 0xC0)  // Modo SVC, deshabilitar IRQ/FIQ
  92 0068 30D09FE5 	    LDR SP, = __stack_top_svc__
  93              	
  94              	    // Modo Abort
  95 006c D7F021E3 	    MSR cpsr_c, #(0x17 | 0xC0)  // Modo Abort, deshabilitar IRQ/FIQ
  96 0070 2CD09FE5 	    LDR SP, = __stack_top_abt__
  97              	
  98              	    // Modo Undefined
  99 0074 DBF021E3 	    MSR cpsr_c, #(0x1B| 0xC0)  // Modo Undefined, deshabilitar IRQ/FIQ
 100 0078 28D09FE5 	    LDR SP, = __stack_top_und__
 101              	
 102              	    // Modo System (generalmente se usa como User con privilegios)
 103 007c DFF021E3 	    MSR cpsr_c, #(0x1F | 0xC0)  // Modo System, deshabilitar IRQ/FIQ
 104 0080 24D09FE5 	    LDR SP, = __stack_top_sys__
 105              	
