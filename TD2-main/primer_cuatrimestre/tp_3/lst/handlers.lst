ARM GAS  src/kernel/handlers.s 			page 1


   1              	/*
   2              	Este archivo define los manejadores de excepciones (handlers). 
   3              	Cada sección (b .) significa que cuando ocurre esa excepción, el procesador 
   4              	se queda en un bucle infinito (esperando que el usuario lo depure).
   5              	 */
   6              	
   7              	
   8              	.global	_reset_vector
   9              	.global handler_UND
  10              	.global handler_SWI
  11              	.global handler_prefetch_abort
  12              	.global handler_data_abort
  13              	.global handler_reserved
  14              	.global handler_IRQ
  15              	.global handler_FIQ
  16              	
  17              	
  18              	.extern kernel_handler_irq
  19              	
  20              	.section .handlers, "ax"
  21              	
  22              	handler_UND:       
  23 0000 FEFFFFEA 	    b .
  24              	
  25              	handler_SWI:         
  26              	    // 1. Guardamos el contexto de la tarea que llamó a la syscall
  27              	    //    (registros R0-R12, LR) en la pila.
  28              	    //    Esto es necesario para que podamos restaurar el contexto después de manejar la syscall.
  29              	    //    El LR se ajusta para que no vuelva a la instrucción de llamada a la syscall,
  30              	    //    sino que vuelva al punto correcto después de manejar la syscall.
  31 0004 04E04EE2 	    SUB LR, LR, #4
  32 0008 FF5F2DE9 	    PUSH {R0-R12, LR}
  33              	
  34              	    // 2. Llamamos al manejador en C, pasándole un puntero al contexto
  35              	    //    guardado (el stack pointer actual)
  36 000c 0D00A0E1 	    MOV R0, SP
  37 0010 FEFFFFEB 	    BL kernel_handler_svc
  38              	
  39              	    // 3. Restauramos el contexto y volvemos a la tarea
  40 0014 FF9FFDE8 	    LDMFD sp!, {R0-R12, PC}^
  41              	
  42              	handler_prefetch_abort:      
  43 0018 FEFFFFEA 	    b .
  44              	
  45              	handler_data_abort:          
  46 001c FEFFFFEA 	    b .
  47              	
  48              	handler_reserved:    
  49 0020 FEFFFFEA 	    b .
  50              	
  51              	handler_IRQ:         
  52              	
  53              	    //Entra la excepcion, se guardan Link register,los registros del momento en donde se esta, el S
  54 0024 04E04EE2 	    SUB LR, LR, #4
  55 0028 FF5F2DE9 	    PUSH {R0-R12, LR}
  56 002c 0D70A0E1 	    MOV R7, SP
  57 0030 00804FE1 	    MRS R8, SPSR
ARM GAS  src/kernel/handlers.s 			page 2


  58 0034 80012DE9 	    PUSH {R7, R8}
  59              	
  60              	    // Manejo de excepcion
  61 0038 0D00A0E1 	    MOV R0, SP
  62 003c FEFFFFEB 	    BL kernel_handler_irq
  63              	
  64              	    //Se vuelve todo como estaba antes, se recontruye la pila
  65 0040 8001BDE8 	    POP {R7,R8}
  66 0044 08F069E1 	    MSR SPSR, R8
  67 0048 07D0A0E1 	    MOV SP, R7
  68 004c FF9FFDE8 	    LDMFD sp!, {R0-R12, PC}^
  69              	
  70              	handler_FIQ:         
  71 0050 FEFFFFEA 	    b .
  72              	
  73              	.end...
